<view class="container">
    <view class="infoInputView">
      <text style="font-size: 50rpx;">会员查询</text>
      <view class="infoSingleInputView">
        <text>号码：</text>
        <input type="number" placeholder="支持关键字搜索" maxlength="11" bindinput="onPhoneChange" style="margin-left: 15rpx;" class="infoInput"></input>
      </view>
      <view class="infoSingleInputView">
        <text>备注：</text>
        <input type="text" placeholder="支持关键字搜索"  maxlength="30" bindinput="onNoteChange" style="margin-left: 15rpx;" class="infoInput"></input>
      </view>
      <button class="searchButton" bindtap="searchVipInfo" style=" width: 350rpx;margin-right: 0;">任一条件搜索</button>
      <text style="font-size: 38rpx;">注：点击卡片进行功能操作</text>
    </view>

    <view class="vipInfoBorder">
      <scroll-view scroll-y="true" style="height: inherit;">
        <!-- 项目内容 --> 
        <view class="vipBorder" wx:for="{{vipInfo}}" bindtap="vipInfoAction" data-userphone="{{item.user_phone}}" data-usernotes="{{item.user_notes}}">
          <text>号码：{{item.user_phone}}</text>
          <block wx:if="{{item.user_notes}}">
            <text>备注：{{item.user_notes}}</text>
          </block>
          <block wx:else>
            <text>备注：(点击添加备注)</text>
          </block>
        </view>
      </scroll-view>
    </view>
</view>