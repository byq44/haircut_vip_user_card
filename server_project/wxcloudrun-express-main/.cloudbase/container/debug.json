{
  "containers": [
    {
      "name": "wxcloudrun-express-main",
      "domain": "",
      "ip": "",
      "mode": "compose"
    }
  ],
  "config": {
    "wxcloudrun-express-main": {
      "containerPort": 80,
      "dockerfilePath": "Dockerfile",
      "buildDir": "",
      "minNum": 0,
      "maxNum": 1,
      "cpu": 0.25,
      "mem": 0.5,
      "policyType": "cpu",
      "policyThreshold": 80,
      "policyDetails": [
        {
          "PolicyType": "cpu",
          "PolicyThreshold": 80
        },
        {
          "PolicyType": "mem",
          "PolicyThreshold": 80
        }
      ],
      "envParams": {
        "MYSQL_USERNAME": "root",
        "MYSQL_PASSWORD": "root",
        "MYSQL_ADDRESS": "host.docker.internal:3308"
      },
      "customLogs": "stdout",
      "initialDelaySeconds": 2,
      "dataBaseName": "nodejs_demo"
    }
  }
}