.expenseRecord {
  margin-top: 8rpx;
  margin-left: 50rpx;
  margin-bottom: 30rpx;
  height: 100%;
  display: flex;
  flex-direction: column;

}

.title {
  display: flex;
  flex-direction: column;
  width: 680rpx;
}

.expenseRecordBorder {
  margin-top: 22rpx;
  width: 650rpx;
  height: 790rpx;
  border: 1px solid #b9b9b9;
  box-shadow: 0 6px 25px 0 rgba(0, 0, 0, .1);
 
}

.recordInfoBorder {
  display: flex;
  flex-direction: column;
  margin:15rpx 10rpx 20rpx 10rpx;
  
  border: 1px solid #d8d7d7;
  box-shadow: 0 3px 30px 0 rgba(0, 0, 0, .1);
  border-radius: 10px;
/* #fda82e #fd9f1c */
  font-size: 40rpx;
  text-indent: 20rpx;
  line-height: 62rpx;
  
}

.sortButton {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 18rpx;
  border: 1px solid #d8d7d7;
  box-shadow: 0 5px 15px 0 rgba(0, 0, 0, .15);
  border-radius: 10px;
  background-color: #f2f2f2;
  font-size: 37rpx;
}

.discountPrice {
  text-decoration: line-through;
  font-size: 35rpx;
  font-weight: 300;
}